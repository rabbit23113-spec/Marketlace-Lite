{
  "name": "@marketplace/apiGateway-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@marketplace/apiGateway"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "dependsOn": [
          "@marketplace/apiGateway:build",
          "@marketplace/apiGateway:serve"
        ],
        "options": {
          "jestConfig": "apps/apiGateway-e2e/jest.config.cts",
          "passWithNoTests": true
        }
      }
    }
  }
}
